# ===== Database (docker-compose 默认) =====
POSTGRES_DB=trade_strategy_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# 应用侧 SQLAlchemy URL（Async）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trade_strategy_ai

# 可选 Redis（如启用 docker-compose 的 redis profile）
REDIS_URL=redis://localhost:6379/0

# ===== Crawler Auth（建议只通过环境变量注入） =====
# TGB_COOKIE=xxx

# ===== LLM（可选；未配置则使用启发式抽取并记录 fallback） =====
# LLM_PROVIDER=openai|anthropic|openai_compatible
# LLM_MODEL=gpt-4.1-mini
# LLM_URL=https://api.openai.com/v1
# LLM_API_KEY=xxx

# ===== Application =====
LOG_LEVEL=INFO
DEBUG=false

# ===== Crawler Proxy（可选） =====
CRAWL_PROXY=

# ===== Market Data（可选） =====
MARKET_DATA_TOKEN=
