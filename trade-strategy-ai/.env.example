# ===== Database（推荐：本机安装 PostgreSQL） =====
# 你可以在本机创建一个专用角色/数据库：
#   user=trade  pass=trade  db=trade_strategy_ai
# 然后配置：
DATABASE_URL=postgresql+asyncpg://trade:trade@localhost:5432/trade_strategy_ai

# 可选 Redis（项目当前默认不强依赖；如使用则自行安装/启动）
REDIS_URL=redis://localhost:6379/0

# ===== Crawler Auth（建议只通过环境变量注入） =====
# TGB_COOKIE=xxx

# ===== LLM（可选；未配置则使用启发式抽取并记录 fallback） =====
# LLM_PROVIDER=openai|anthropic|openai_compatible
# LLM_MODEL=gpt-4.1-mini
# LLM_URL=https://api.openai.com/v1
# LLM_API_KEY=xxx

# ===== Application =====
LOG_LEVEL=INFO
DEBUG=false

# ===== Crawler Proxy（可选） =====
CRAWL_PROXY=

# ===== Market Data（可选） =====
MARKET_DATA_TOKEN=
